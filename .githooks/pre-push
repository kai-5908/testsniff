#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-}"
remote_url="${2:-}"

while read -r local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    echo "pre-push: direct pushes to main are not allowed in this repository" >&2
    echo "pre-push: push a topic branch and open or update a pull request instead" >&2
    exit 1
  fi
done

if ! command -v uv >/dev/null 2>&1; then
  echo "pre-push: uv is required" >&2
  exit 1
fi

echo "pre-push: validating branch before push to ${remote_name:-<unknown>} ${remote_url:-}"
uv run ruff check src tests
uv run ty check src

pytest_log="$(mktemp)"
if ! uv run pytest -q >"$pytest_log" 2>&1; then
  cat "$pytest_log" >&2
  if grep -q "Required test coverage of 100% not reached" "$pytest_log"; then
    echo "pre-push: coverage must reach 100% before push." >&2
    echo "pre-push: do not add superficial tests only to raise the percentage." >&2
    echo "pre-push: understand the domain, user flows, and failure modes, then add tests that verify meaningful behavior." >&2
  fi
  rm -f "$pytest_log"
  exit 1
fi

cat "$pytest_log"
rm -f "$pytest_log"
